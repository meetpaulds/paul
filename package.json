{
  "name": "paul",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @paul/storybook dev",
    "build": "pnpm --filter @meetpaul/ui build",
    "build:storybook": "pnpm --filter @paul/storybook build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "publish:ui": "pnpm --filter @meetpaul/ui publish --no-git-checks"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "latest",
    "eslint": "latest",
    "prettier": "latest"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.0.0"
}
