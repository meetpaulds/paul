{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../packages/ui-vue/src/*"],
      "@meetpaul/ui-vue": ["../../packages/ui-vue/src/index.ts"],
      "@meetpaul/ui-vue/*": ["../../packages/ui-vue/src/components/*.vue"]
    }
  },
  "include": ["src", ".storybook"]
}
