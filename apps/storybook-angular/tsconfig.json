{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@meetpaul/ui-angular": ["../../packages/ui-angular/dist"],
      "@meetpaul/ui-angular/*": ["../../packages/ui-angular/dist/*"],
      "@meetpaul/tokens": ["../../packages/tokens/src"],
      "@meetpaul/tokens/*": ["../../packages/tokens/src/*"]
    }
  },
  "include": ["src", ".storybook"]
}
