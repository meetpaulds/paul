{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@meetpaul/ui-svelte/*": ["../../packages/ui-svelte/src/lib/components/*"],
      "@meetpaul/tokens/*": ["../../packages/tokens/src/*"]
    }
  },
  "include": ["src", ".storybook"]
}
